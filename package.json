{
  "name": "my-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "android": "npm run android --workspace=demoapp",
    "ios": "npm run ios --workspace=demoapp",
    "ios:pod": "npm run ios:pod --workspace=demoapp",
    "start": "npm run start --workspace=demoapp"
  }
}